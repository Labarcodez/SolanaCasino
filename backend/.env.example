PORT=3001
NODE_ENV=development
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RPC_FALLBACK=https://api.mainnet-beta.solana.com
# Optional: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_RPC_URL=
PROGRAM_ID=Be5brMe2AvA68zEdiFKxa6KfYJdeQAeY12eWtZiC41vU
# Enables on-chain mode (oracle for crash rounds). Same key used to deploy program.
PROGRAM_AUTHORITY_PRIVATE_KEY=
CASINO_WALLET_ADDRESS=FMmho438Vv1Y9nov4mtfHZ4pYSZV8NfubiCeCB3bbGCb
# Legacy custodial withdrawals — not needed in on-chain mode
CASINO_WALLET_PRIVATE_KEY=
# Admin dashboard access — wallet pubkey that can pause casino and process withdrawals
ADMIN_WALLET=
# Auto-generated by scripts/setup.sh if empty — REQUIRED in production
JWT_SECRET=
FRONTEND_URL=http://localhost:5173
# Comma-separated extra CORS origins for staging/production
CORS_ORIGINS=
# Set to true when serving built frontend from backend (production)
SERVE_FRONTEND=false
# Phantom Portal app ID — enables Google/Apple email login
PHANTOM_APP_ID=
HOUSE_EDGE=0.05
MIN_BET_SOL=0.001
MAX_BET_SOL=10
MIN_WITHDRAW_SOL=0.01
