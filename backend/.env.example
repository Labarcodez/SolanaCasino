PORT=3001
NODE_ENV=development
SOLANA_CLUSTER=mainnet-beta
# Option A (recommended): Alchemy free tier — https://dashboard.alchemy.com
ALCHEMY_API_KEY=
# Option B: full URL override (leave ALCHEMY_API_KEY empty if using this)
SOLANA_RPC_URL=
# Free aggregator fallback if primary fails
SOLANA_RPC_FALLBACK=https://solana.drpc.org
# Optional: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_RPC_URL=
PROGRAM_ID=Be5brMe2AvA68zEdiFKxa6KfYJdeQAeY12eWtZiC41vU
# Enables on-chain mode (oracle for crash rounds). Same key used to deploy program.
PROGRAM_AUTHORITY_PRIVATE_KEY=
CASINO_WALLET_ADDRESS=3BSEfRdZsZz87EDafo5rcY87uLt6RCbPqQZsmNMxYfcu
# Legacy custodial withdrawals — required for instant payouts
CASINO_WALLET_PRIVATE_KEY=
# Admin dashboard access — wallet pubkey that can pause casino and process withdrawals
ADMIN_WALLET=
# Auto-generated by scripts/setup.sh if empty — REQUIRED in production
JWT_SECRET=
FRONTEND_URL=http://localhost:5173
# AWS HTTPS (production deploy via npm run aws:deploy)
AWS_DOMAIN_NAME=orbit-casino.com
AWS_ACM_CERTIFICATE_ARN=
# Email for CloudWatch alarm SNS (confirm subscription after deploy)
AWS_ALARM_EMAIL=
# Optional Sentry DSN (backend). Frontend uses VITE_SENTRY_DSN at build time.
SENTRY_DSN=
# Pause new bets when hot wallet SOL < player liabilities (default: on in production)
BLOCK_BETS_WHEN_INSOLVENT=
# Pending withdrawal confirmation interval (ms)
WITHDRAW_FINALIZE_INTERVAL_MS=45000
# Optional: metadata URI base for Pump.fun token launch (defaults to FRONTEND_URL)
PUBLIC_API_URL=https://orbit-casino.com
# Persistent SQLite path (set automatically on ECS EFS — do not change in production)
# SQLITE_PATH=/app/backend/data/casino.db
# Set after launching site token on Bags.fm (live mode)
ORBIT_TOKEN_MINT=
ORBIT_TOKEN_LAUNCH_PLATFORM=pump
ORBIT_TOKEN_LAUNCH_STATUS=coming_soon
# Retired mints (comma-separated) — never shown as the site token after a relaunch
ORBIT_TOKEN_DEPRECATED_MINTS=F2Kg2sH7q8CbH14ouZySE41vtwoJTbiuYCWeppR7BAGS,4T4seM2KAyQ23yF6aqnQHWiuGkuAp22FSs4fNbGPBAGS
# Bags launch script (scripts/launch-orbit-bags.ts) — optional overrides
# ORBIT_LAUNCH_INITIAL_BUY_USD=140
# ORBIT_LAUNCH_SOL_PRICE_USD=150
# BAGS_FM_CONFIG_TYPE=fa29606e-5e48-4c37-827f-4b03d58ee23d
# Creator profile before coin launch
BAGS_FM_PROFILE_URL=https://bags.fm/@orbitsolanacasino
# API key from https://dev.bags.fm — server-side only, never commit
BAGS_FM_API_KEY=
# Full coin URL after launch, e.g. https://bags.fm/YourMintAddress
BAGS_FM_TOKEN_URL=
# Comma-separated extra CORS origins for staging/production
CORS_ORIGINS=
# Set to true when serving built frontend from backend (production)
SERVE_FRONTEND=false
# Phantom Portal app ID — enables Google/Apple email login
PHANTOM_APP_ID=
HOUSE_EDGE=0.06
# Crash instant-bust modulus (1/N ≈ house edge). 20 ≈ 5%.
CRASH_HOUSE_MOD=20
# Limbo house edge (default 0.05 = 95% RTP) and minimum target multiplier
LIMBO_HOUSE_EDGE=0.05
LIMBO_MIN_TARGET=2
MIN_BET_SOL=0.001
MAX_BET_SOL=10
MIN_WITHDRAW_SOL=0.01
# Pump creator-fee lottery (claimable fees only — never treasury deposit float)
# Every 5 min: claim Pump creator fees → 50% to weighted random holder, 50% stays as claimed
TOKEN_REWARD_LOTTERY_ENABLED=true
TOKEN_REWARD_INTERVAL_MS=300000
TOKEN_REWARD_MIN_CLAIM_SOL=0.002
TOKEN_REWARD_WINNER_BPS=5000

